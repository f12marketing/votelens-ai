# Railway Environment Variables Template
# Copy this file to .env.railway and fill in the values
# DO NOT commit .env.railway to version control

# ===========================================
# FRONTEND ENVIRONMENT VARIABLES
# ===========================================

# API URL (auto-configured by Railway)
VITE_API_URL=https://api.vote-lens-ai.railway.app/api/v1

# Application URL (auto-configured by Railway)
VITE_APP_URL=https://vote-lens-ai.railway.app

# ===========================================
# BACKEND ENVIRONMENT VARIABLES
# ===========================================

# Node Environment
NODE_ENV=production

# Server Port
PORT=3000

# Database URL (auto-injected by Railway PostgreSQL service)
DATABASE_URL=${{DATABASE_URL}}

# Redis URL (if using Redis service)
REDIS_URL=${{REDIS_URL}}

# JWT Configuration
JWT_SECRET=${{JWT_SECRET}}
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# AI Services
GEMINI_API_KEY=${{GEMINI_API_KEY}}
OPENAI_API_KEY=${{OPENAI_API_KEY}}
AI_MODEL=gemini-pro
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7

# CORS Configuration
CORS_ORIGIN=https://vote-lens-ai.railway.app
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=csv,xlsx,xls,json
UPLOAD_DIR=/tmp/uploads

# Cache Configuration
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000

# Logging Configuration
LOG_LEVEL=warn
LOG_FORMAT=json

# Railway-specific
RAILWAY_ENVIRONMENT=production
RAILWAY_SERVICE_NAME=backend

# Database Pool Configuration
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
